{
	"$schema": "../node_modules/@companion-module/base/assets/manifest.schema.json",
	"id": "sherwoodsystems-sherpresent",
	"name": "SherPresent",
	"shortname": "sherpresent",
	"description": "Network based multi-platform presentation remote to integrate with the Sherwood Systems clicker adapter.",
	"version": "0.1.0",
	"license": "MIT",
	"repository": "git+https://github.com/sherwoodsystems/companion-module-sherpresent.git",
	"bugs": "https://github.com/sherwoodsystems/companion-module-sherpresent/issues",
	"maintainers": [
		{
			"name": "Cameron Slipp",
			"email": "cameron@sherwoodsystems.com"
		}
	],
	"runtime": {
		"type": "node22",
		"api": "nodejs-ipc",
		"apiVersion": "0.0.0",
		"entrypoint": "../dist/main.js"
	},
	"bonjourQueries": {
		"bonjourDevice": {
			"type": "_sher-present",
			"protocol": "udp"
		}
	},
	"legacyIds": [],
	"manufacturer": "Sherwood Systems",
	"products": ["SherPresent"],
	"keywords": ["PowerPoint", "Keynote", "Canva", "Presentation", "Remote"]
}
